{
  "name": "bandungaja",
  "version": "1.0.0",
  "description": "BandungAja - Aplikasi Wisata Kota Bandung",
  "main": "main.js",
  "author": "BandungAja Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "build:linux": "electron-builder build --linux",
    "build:all": "electron-builder build --win --mac --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.bandungaja.app",
    "productName": "BandungAja",
    "copyright": "Copyright © 2025 BandungAja Team",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "app.js",
      "asset/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        "portable"
      ],
      "icon": "asset/ICON-APP-BDGAJA.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "asset/ICON-APP-BDGAJA.png",
      "category": "public.app-category.travel"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "asset/ICON-APP-BDGAJA.png",
      "category": "Travel"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "asset/ICON-APP-BDGAJA.png",
      "installerHeaderIcon": "asset/ICON-APP-BDGAJA.png"
    }
  }
}
